# pyproject.toml.jinja
[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "データ分析プロジェクト: {{ project_name }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
dependencies = [
    # 全プロジェクト共通で必ず使う分析ライブラリがあればここに記載
    "fastapi>=0.136.1",
    "uvicorn>=0.46.0",
]

[tool.uv]
dev-dependencies = [
    # 品質保障のための共通ツール群
    "pytest>=9.0.3",
    "ruff>=0.15.12",
    "mcp>=1.27.0",
    "copier>=9.0.0",
]

[tool.ruff]
line-length = 120
